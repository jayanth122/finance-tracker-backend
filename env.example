# App
NODE_ENV=production
PORT=5000

# CORS
# Comma-separated list of allowed frontend origins.
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# API hardening
JSON_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
